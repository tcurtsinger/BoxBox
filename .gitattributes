# Normalize line endings: store LF in the repo, check out native. Stops the
# LF→CRLF diff noise the audit flagged on Windows checkouts.
* text=auto eol=lf

# Explicit text types (kept LF regardless of platform).
*.rs    text eol=lf
*.ts    text eol=lf
*.tsx   text eol=lf
*.js    text eol=lf
*.mjs   text eol=lf
*.json  text eol=lf
*.css   text eol=lf
*.html  text eol=lf
*.md    text eol=lf
*.toml  text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf

# Binary assets — never touch their bytes.
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.icns  binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.otf   binary
*.wav   binary
*.mp3   binary
