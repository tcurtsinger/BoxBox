# Root-level ignores for the BoxBox app.

# Dependencies
node_modules/

# Build output
dist/
build/
target/
*.tsbuildinfo

# Logs and probe scratch
*.log
*.jsonl

# Per-driver Tuner profiles (runtime data, not source)
profiles/

# Tooling caches / local agent config
.claude/
.impeccable/

# Environment / secrets
.env
.env.*
!.env.example

# OS cruft
.DS_Store
Thumbs.db
Desktop.ini

# Editor scratch
*.swp
