# Root-level ignores for the BoxBox monorepo.
# Each product (Race Control/, Tuner/) also carries its own .gitignore.

# Dependencies
node_modules/

# Build output
dist/
build/
*.tsbuildinfo

# Logs and probe scratch
*.log
*.jsonl

# Per-driver Tuner profiles (runtime data, not source)
profiles/

# Environment / secrets
.env
.env.*
!.env.example

# OS cruft
.DS_Store
Thumbs.db
Desktop.ini

# Editor scratch
*.swp
